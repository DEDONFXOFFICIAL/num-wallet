{
  "expo": {
    "name": "Num Wallet",
    "slug": "num-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "numwallet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050A0E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.numwallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#050A0E"
      },
      "package": "app.numwallet"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}

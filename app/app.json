{
  "expo": {
    "name": "Num Wallet",
    "slug": "num-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./logo/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "numwallet",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.numwallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo/android-icon-foreground.png",
        "backgroundColor": "#050A0E"
      },
      "package": "app.numwallet"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-mail-composer",
      [
        "expo-splash-screen",
        {
          "image": "./logo/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050A0E"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edd21caa-7e01-4cc1-99f9-a8c25ac36e6b"
      }
    },
    "owner": "dedonfxofficial"
  }
}
